{
  "permissions": {
    "allow": [
      "Bash(git --version)",
      "Bash(gh --version)",
      "Bash(git ls-remote *)",
      "Bash(git clone *)",
      "Bash(git init *)",
      "Bash(git remote *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(php --version)",
      "Bash(php tests/run.php)",
      "PowerShell($php = \\(Get-Command php -ErrorAction SilentlyContinue\\).Source; if \\($php\\) { Write-Output \"PHP: $php\"; & php --version | Select-Object -First 1 } else { Write-Output \"PHP not found in PATH\" })",
      "Bash(awk -F: '{s+=$2} END{print s}')",
      "Bash(git config *)",
      "Bash(echo \"user.name: $\\(git config user.name\\)\")",
      "Bash(echo \"user.email: $\\(git config user.email\\)\")",
      "Bash(git add *)",
      "Bash(git commit *)"
    ]
  }
}
