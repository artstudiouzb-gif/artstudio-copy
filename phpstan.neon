parameters:
    bootstrapFiles:
        - phpstan-bootstrap.php
    level: 3
    paths:
        - app
        - public/index.php
    excludePaths:
        - tests/*
    # Production-код по-прежнему использует собственный автолоадер; Composer
    # подключён только для воспроизводимых инструментов разработки.
    scanDirectories:
        - app
        - database
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
