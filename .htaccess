# Этот файл нужен ТОЛЬКО если хостинг не позволяет указать document root
# на папку /public (например, дешёвый shared-хостинг, где сайт = корень
# аккаунта). Если вы настраиваете document root на /public в панели
# хостинга или в конфиге веб-сервера — этот файл можно удалить.
#
# Защита реализована правилами mod_rewrite (флаг [F] → 403): в отличие от
# связки «Require all denied на *.php + точечное разрешение точек входа»,
# она одинаково работает на Apache 2.4 и LiteSpeed — на части shared-
# хостингов слияние Require-секций между .htaccess отличается от каноничного
# Apache, и запрет побеждал разрешение, отдавая 403 в том числе установщику.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Служебные каталоги недоступны напрямую (403 до проксирования в public/).
    RewriteRule ^(app|config|database|storage|templates|tests|docs)(/|$) - [F]

    # Скрытые файлы и каталоги (.git, .env и т.п.); .well-known оставлен для ACME.
    RewriteRule (^|/)\.(?!well-known(/|$)) - [F]

    # Любой .php вне public/ запрещён (config/config.php, database/*.php
    # и т.д. не должны исполняться через веб). Исключения: index.php и
    # download.php — виртуальные точки входа в корне: фронт-контроллер
    # public/.htaccess (RewriteBase /) переписывает маршруты на /index.php,
    # а правило проксирования ниже возвращает его в public/.
    RewriteRule ^(?!public/|index\.php$|download\.php$).*\.php$ - [F]

    RewriteRule ^$ public/ [L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule (.*) public/$1 [L]
</IfModule>

# Запрет листинга директорий (storage/logs, database и т.п.).
Options -Indexes

# Дампы БД, конфиги, логи, lock-файлы не должны отдаваться как статика.
# Безусловный запрет без исключений — не зависит от порядка слияния секций.
<IfModule mod_authz_core.c>
    <FilesMatch "\.(sql|env|log|lock|ini)$">
        Require all denied
    </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(sql|env|log|lock|ini)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# Fallback: если mod_rewrite недоступен, сайт через корень всё равно не
# работает (нет проксирования в public/) — глушим .php полностью, чтобы
# служебные скрипты не исполнялись напрямую.
<IfModule !mod_rewrite.c>
    <IfModule mod_authz_core.c>
        <FilesMatch "\.php$">
            Require all denied
        </FilesMatch>
    </IfModule>
    <IfModule !mod_authz_core.c>
        <FilesMatch "\.php$">
            Order allow,deny
            Deny from all
        </FilesMatch>
    </IfModule>
</IfModule>
