<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Существующие файлы и папки (assets, uploads, download.php) отдаются напрямую
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Всё остальное — через единую точку входа
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # Долгий кэш для версионированных ассетов (задача 127). URL меняется через
    # ?v=<hash> при обновлении файла (App\Core\Asset::url), поэтому CDN отдаёт
    # новую версию без ручной очистки, а старые кэшируются «навсегда».
    <FilesMatch "\.(css|js|woff2?|ttf|eot|svg|jpe?g|png|gif|webp|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

Options -Indexes
DirectoryIndex index.php

# Единственные .php с разрешённым прямым доступом — точки входа приложения.
# Это отменяет унаследованный из корневого .htaccess deny-all на .php (задача
# 1.1) для fallback-сценария (docroot = корень проекта). Порядок важен:
# сначала общий запрет, затем явные разрешения — последняя совпавшая секция
# побеждает при слиянии, поэтому index/download.php гарантированно доступны.
<IfModule mod_authz_core.c>
    <FilesMatch "\.php$">
        Require all denied
    </FilesMatch>
    <Files "index.php">
        Require all granted
    </Files>
    <Files "download.php">
        Require all granted
    </Files>
</IfModule>
<IfModule !mod_authz_core.c>
    <Files "index.php">
        Order allow,deny
        Allow from all
    </Files>
    <Files "download.php">
        Order allow,deny
        Allow from all
    </Files>
</IfModule>
